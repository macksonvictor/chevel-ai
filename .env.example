CHEVEL_PUBLIC_MODEL=HELI 1.5
CHEVEL_MODEL=llama3.1:8b
CHEVEL_MAX_HISTORY=20
OLLAMA_HOST=http://127.0.0.1:11434

# Optional private user profile. The default file is ignored by Git.
# CHEVEL_USER_PROFILE_PATH=data/memory/profile.local.json

# Optional local config override. Prefer data/configs/*.local.json for
# machine-specific settings.
# CHEVEL_CONFIG_PATH=data/configs/chevel.local.json

# Optional Porcupine wake-word setup. Keep real keys out of Git.
# PORCUPINE_ACCESS_KEY=
# CHEVEL_WAKE_WORD_PATH=
